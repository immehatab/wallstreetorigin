# ============================================================
#  Trading Terminal — environment
#  Module 1 (Data Foundation) needs NONE of these. Every source
#  it uses is keyless. These are for later modules — sign up as
#  you go and the matching adapters will light up automatically.
# ============================================================

# --- AI Decision Agents (Module 4) ---
# Anthropic-compatible endpoint. For Agent Router, set BASE_URL to its
# Claude-compatible endpoint and API_KEY to your Agent Router key.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- Macro / rates / econ calendar (Module 2 News+Macro) ---
FRED_API_KEY=            # https://fred.stlouisfed.org/docs/api/api_key.html (free)
FINNHUB_API_KEY=         # https://finnhub.io  (free tier: news + econ calendar)

# --- Premium price / tick data (optional upgrade) ---
TWELVEDATA_API_KEY=      # https://twelvedata.com (free 800 req/day; good XAUUSD)
POLYGON_API_KEY=         # https://polygon.io (paid, low-latency)

# --- On-chain / derivatives flow (Module 5 BTC engine) ---
COINGLASS_API_KEY=       # liquidation maps, funding, OI
GLASSNODE_API_KEY=       # on-chain / exchange netflows (paid)

# --- News APIs (optional) ---
NEWSAPI_KEY=             # https://newsapi.org
MARKETAUX_API_KEY=       # https://marketaux.com (financial news + sentiment)
